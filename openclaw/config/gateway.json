{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "models": {
    "default": "groq/llama-3.3-70b-versatile",
    "fallbacks": [
      "google/gemini-2.5-flash",
      "ollama/qwen3:8b"
    ],
    "providers": {
      "groq": {
        "type": "openai-compatible",
        "baseUrl": "https://api.groq.com/openai/v1",
        "models": ["llama-3.3-70b-versatile"]
      },
      "google": {
        "type": "google",
        "models": ["gemini-2.5-flash"]
      },
      "ollama": {
        "type": "ollama",
        "host": "http://localhost:11434",
        "models": ["qwen3:8b"]
      }
    }
  },
  "agent": {
    "restricted": true,
    "allowedTools": [
      "list_recent_emails",
      "get_email_content",
      "summarize_emails",
      "classify_emails",
      "draft_reply",
      "send_email",
      "confirm_send",
      "agent_query"
    ],
    "blockedCommands": [
      "rm",
      "sudo",
      "chmod",
      "kill",
      "shutdown"
    ]
  }
}
